@page
@model EventModel
@{
    ViewData["Title"] = Model.EventName;
}

<style>
    /* Makes the description text sparser and highly readable */
    .event-description {
        font-size: 1.1rem;
        line-height: 1.8;
        white-space: pre-wrap; /* Forces the browser to respect hidden plain-text newlines */
        word-break: break-word;
    }

        /* Adds extra breathing room between HTML paragraphs if the description is formatted */
        .event-description p {
            margin-bottom: 1.5rem;
        }
</style>

<div class="container mt-5">
    <div class="row gx-5">

        <div class="col-lg-6 text-center mb-5">
            <h1 class="fw-bold">@Model.EventName</h1>
            <h4 class="text-muted mt-3">Starts at: @Model.StartTimeFormatted</h4>

            <div class="card mt-4 shadow-sm border-0 bg-light">
                <div class="card-body py-5">
                    <h2 id="timer" class="display-4 text-primary fw-bold mb-0">Loading...</h2>
                </div>
            </div>

            <h6 class="text-muted mt-4">Ends at: @Model.EndTimeFormatted</h6>

            @if (!string.IsNullOrEmpty(Model.HtmlLink))
            {
                <div class="mt-5">
                    <a href="@Model.HtmlLink" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary rounded-pill px-4 py-2 shadow-sm">
                        View Original Event in Google Calendar
                    </a>
                </div>
            }
        </div>

        <div class="col-lg-6 d-flex flex-column gap-4">

            @if (!string.IsNullOrEmpty(Model.DisplayLocationText))
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 ps-4">
                        <h5 class="text-muted mb-1">Location</h5>
                        <p class="text-dark fw-medium mb-3">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i> @Model.DisplayLocationText
                        </p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.MapIframeSrc))
                    {
                        <div class="card-body p-0">
                            <iframe width="100%"
                                    height="350"
                                    style="border:0; border-radius: 0 0 0.375rem 0.375rem;"
                                    loading="lazy"
                                    allowfullscreen
                                    referrerpolicy="no-referrer-when-downgrade"
                                    src="@Model.MapIframeSrc">
                            </iframe>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(Model.MapExternalUrl))
                    {
                        <div class="card-body bg-light text-center py-5" style="border-radius: 0 0 0.375rem 0.375rem;">
                            <h6 class="text-muted mb-4">This location uses a shortened link that cannot be displayed directly here.</h6>
                            <a href="@Model.MapExternalUrl" target="_blank" rel="noopener noreferrer" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                                Open map in a new tab
                            </a>
                        </div>
                    }
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 ps-4">
                        <h5 class="text-muted mb-0">Event Details</h5>
                    </div>
                    <div class="card-body p-4 event-description text-secondary">
                        @Html.Raw(Model.Description)
                    </div>
                </div>
            }
            @if (string.IsNullOrEmpty(Model.Description) && string.IsNullOrEmpty(Model.DisplayLocationText))
            {
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body d-flex align-items-center justify-content-center p-4">
                        <span class="text-muted fst-italic">No additional details provided for this event.</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const targetTimestamp = @(Model.TargetTimestamp.HasValue ? Model.TargetTimestamp.Value.ToString() : "null");

        if (!targetTimestamp) {
            document.getElementById("timer").innerText = "All-day event (No exact time)";
        } else {
            const interval = setInterval(() => {
                const now = new Date().getTime();
                const distance = targetTimestamp - now;

                if (distance < 0) {
                    clearInterval(interval);
                    document.getElementById("timer").innerText = "Event has started!";
                    return;
                }

                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById("timer").innerText =
                    `${days}d ${hours}h ${minutes}m ${seconds}s`;
            }, 1000);
        }
    </script>
}